{
  "theme": "base",
  "themeVariables": {
    "fontFamily": "-apple-system, Segoe UI, Helvetica Neue, system-ui, sans-serif",
    "fontSize": "16px",

    "background": "#0f172a",
    "primaryColor": "#1e293b",
    "primaryBorderColor": "#475569",
    "primaryTextColor": "#e2e8f0",
    "secondaryColor": "#334155",
    "secondaryBorderColor": "#64748b",
    "secondaryTextColor": "#e2e8f0",
    "tertiaryColor": "#1e293b",
    "tertiaryBorderColor": "#475569",
    "tertiaryTextColor": "#e2e8f0",

    "lineColor": "#94a3b8",
    "textColor": "#e2e8f0",
    "mainBkg": "#1e293b",
    "secondBkg": "#334155",

    "actorBkg": "#1e293b",
    "actorBorder": "#fbbf24",
    "actorTextColor": "#fde68a",
    "actorLineColor": "#94a3b8",

    "signalColor": "#cbd5e1",
    "signalTextColor": "#e2e8f0",

    "labelBoxBkgColor": "#1e293b",
    "labelBoxBorderColor": "#fbbf24",
    "labelTextColor": "#fde68a",

    "loopTextColor": "#fde68a",
    "noteBkgColor": "#1e293b",
    "noteBorderColor": "#a78bfa",
    "noteTextColor": "#c4b5fd",

    "activationBkgColor": "#475569",
    "activationBorderColor": "#fbbf24",

    "sequenceNumberColor": "#0f172a"
  },
  "sequence": {
    "diagramMarginX": 60,
    "diagramMarginY": 40,
    "actorMargin": 100,
    "boxMargin": 14,
    "boxTextMargin": 8,
    "noteMargin": 14,
    "messageMargin": 50,
    "messageAlign": "center",
    "mirrorActors": true,
    "bottomMarginAdj": 10,
    "useMaxWidth": false,
    "wrap": true,
    "showSequenceNumbers": true
  }
}
